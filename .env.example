# git-commit-summarizer environment variables
# Copy to .env and fill in your values: cp .env.example .env

# Path to your LLM CLI binary path
export LLM_MAIN_ENTRY_BIN=llm

# Optional: comma-separated list of blocked words (holy-word / profanity check)
# Required by ENABLE_HOLY_WORD_CHECK; ignored if that variable is not set.
export HOLY_WORDS=""

# Optional: enable holy word / profanity check before commits
# export ENABLE_HOLY_WORD_CHECK=1
